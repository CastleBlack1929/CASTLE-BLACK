import pandas as pd

def verificar_usuario(usuario, contrasena):
    # Leer el archivo Excel
    df = pd.read_excel('usuarios.xlsx', engine='openpyxl')

    # Verificar si el usuario y la contraseña están en el archivo
    usuario_valido = df[(df['usuario'] == usuario) & (df['contraseña'] == contrasena)]

    if not usuario_valido.empty:
        return True
    else:
        return False

# Ejemplo de uso
usuario = input("Introduce tu usuario: ")
contrasena = input("Introduce tu contraseña: ")

if verificar_usuario(usuario, contrasena):
    print("¡Verificación exitosa!")
else:
    print("Usuario o contraseña incorrectos.")
